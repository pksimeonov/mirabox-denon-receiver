			"Tooltip": "Displays the current volume and allows for adjustment.",
			"PropertyInspectorPath": "ui/action.html",
			"Controllers": [
				"Keypad",
				"Encoder",
				"Knob"
			],
			"DisableAutomaticStates": true,
			"Encoder": {
				"layout": "$B1",
				"TriggerDescription": {
					"Push": "Mute/Unmute",
					"Rotate": "Adjust Volume",
					"Touch": "Mute/Unmute"
				}
			},
			"States": [
				{
					"Name": "Unmute",
