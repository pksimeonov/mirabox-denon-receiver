					"Push": "Reset to 0dB",
					"Rotate": "Adjust Sub Level",
					"Touch": "Reset to 0dB"
				}
			},
			"States": [
				{
					"Name": "SubLevel",
					"Image": "imgs/actions/sublevel/sublevel",
