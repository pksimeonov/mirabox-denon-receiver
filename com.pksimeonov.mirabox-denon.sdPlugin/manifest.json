				{
					"Name": "Mute",
					"Image": "imgs/actions/volume/volumeMute",
					"TitleAlignment": "bottom",
					"FontSize": "10"
				},
				{
					"Name": "VolumeUp",
					"Image": "imgs/actions/volume/volumeUp",
					"TitleAlignment": "bottom",
					"FontSize": "10"
				},
				{
					"Name": "VolumeDown",
					"Image": "imgs/actions/volume/volumeDown",
					"TitleAlignment": "bottom",
					"FontSize": "10"
				}
			]
		},
		{
			"Name": "Power Control",
